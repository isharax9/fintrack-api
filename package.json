{
  "name": "fintrack-api",
  "version": "1.0.0",
  "description": "FinTrack Backend MVP",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/bootstrap.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:integration": "vitest run src/integration",
    "test:watch": "vitest",
    "security:audit": "npm audit --audit-level=high",
    "ci:verify": "npm run prisma:generate && npx prisma validate && npm run build && npm test && RUN_DB_INTEGRATION=1 npm run test:integration && npm run security:audit",
    "start": "node dist/bootstrap.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/env": "^6.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@fastify/type-provider-typebox": "^6.1.0",
    "@prisma/client": "^5.22.0",
    "@sinclair/typebox": "^0.32.15",
    "@types/node": "^20.12.7",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "node-cron": "^4.2.1",
    "pdfkit": "^0.15.0",
    "pdfkit-table": "^0.1.99",
    "resend": "^6.12.4",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/pdfkit": "^0.13.4",
    "prisma": "^5.22.0",
    "vitest": "^4.1.8"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "overrides": {
    "fast-uri": "3.1.2"
  }
}
